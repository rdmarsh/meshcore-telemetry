      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "RF Link Health",
          "description": "RSSI, SNR, and noise floor per node on the same axes. The gap between RSSI and noise floor determines effective SNR. Values converging toward the noise floor indicate a link approaching its limit.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "efjymvmsrry0wb"
                      },
                      "spec": {
                        "query": "from(bucket: \"meshcore\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_status\")\n  |> filter(fn: (r) =>\n      r._field == \"last_snr\" or\n      r._field == \"last_rssi\" or\n      r._field == \"noise_floor\"\n  )\n  |> group(columns: [\"node\", \"_field\"])\n  |> aggregateWindow(every:15m, fn:mean, createEmpty:false)"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
