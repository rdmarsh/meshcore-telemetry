                      },
                      "spec": {
                        "query": "from(bucket: \"meshcore\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn:(r)=>r._measurement==\"meshcore_trace_result\")\n  |> filter(fn:(r)=>r._field==\"success\")\n  |> map(fn:(r)=>({\n      _time: r._time,\n      _value: float(v:r._value) * 100.0\n  }))\n  |> group()\n  |> aggregateWindow(every:6h, fn:mean, createEmpty:false)\n"
