    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Reliability by Site (1h)",
          "description": "Percentage of trace attempts that succeeded per site, averaged over 1-hour windows. 100% means all paths to that site were reachable. Drops show which specific node degraded when a change was made. Gaps mean no data was collected.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "efjymvmsrry0wb"
                      },
                      "spec": {
                        "query": "from(bucket: \"meshcore\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn:(r)=>r._measurement==\"meshcore_trace_result\")\n  |> filter(fn:(r)=>r._field==\"success\")\n  |> map(fn:(r)=>({\n      _time: r._time,\n      _value: float(v:r._value) * 100.0,\n      site: r.site\n  }))\n  |> group(columns: [\"site\"])\n  |> aggregateWindow(every:1h, fn:mean, createEmpty:false)\n"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
