      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Trace Success Rate",
          "description": "Percentage of trace attempts that succeeded per route, over 15-minute windows. 100% is ideal; drops indicate the route becoming intermittently or completely unreachable.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "efjymvmsrry0wb"
                      },
                      "spec": {
                        "query": "from(bucket: \"meshcore\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_trace_result\")\n  |> filter(fn: (r) => r._field == \"success\")\n  |> map(fn: (r) => ({\n      _time: r._time,\n      _value: float(v: r._value) * 100.0,\n      route: r.path + \" : \" + r.site\n  }))\n  |> group(columns: [\"route\"])\n  |> aggregateWindow(every: 15m, fn: mean, createEmpty: false)"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
