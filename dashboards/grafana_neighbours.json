      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Neighbour SNR",
          "description": "SNR (dB) of each RF neighbour as seen by each reporting node. Label format: reporting-node → neighbour-pubkey. Higher is better; below 0 dB the signal is at or below the noise floor. Gaps mean the node did not respond.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "efjymvmsrry0wb"
                      },
                      "spec": {
                        "query": "from(bucket: \"meshcore\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_neighbours\")\n  |> filter(fn: (r) => r._field == \"snr\")\n  |> map(fn: (r) => ({\n      _time: r._time,\n      _value: r._value,\n      series: r.node + \" → \" + r.neighbour\n  }))\n  |> group(columns: [\"series\"])\n  |> aggregateWindow(every: 15m, fn: last, createEmpty: false)"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
