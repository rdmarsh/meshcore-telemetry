{
  "kind": "Dashboard",
  "apiVersion": "dashboard.grafana.app/v2",
  "metadata": {
    "name": "f21ab472-5d21-4a89-9db9-6a39569dd681",
    "namespace": "default",
    "labels": {},
    "annotations": {
      "grafana.app/folder": "",
      "grafana.app/saved-from-ui": "Grafana v13.0.1 (a100054f)"
    }
  },
  "spec": {
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "query": {
            "kind": "DataQuery",
            "group": "grafana",
            "version": "v0",
            "datasource": {
              "name": "-- Grafana --"
            },
            "spec": {}
          },
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "builtIn": true
        }
      }
    ],
    "cursorSync": "Off",
    "editable": true,
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Failure Reasons",
          "description": "Count of trace failures in the time range grouped by failure reason. Shows what is causing paths to be unreachable. A high count for a specific reason indicates a systematic issue.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "efjymvmsrry0wb"
                      },
                      "spec": {
                        "query": "from(bucket:\"meshcore\")\n  |> range(start: v.timeRangeStart)\n  |> filter(fn:(r)=> r._measurement==\"meshcore_trace_result\")\n  |> filter(fn:(r)=> r.failure_reason != \"\")\n  |> filter(fn:(r)=> r._field==\"success\")\n  |> group(columns:[\"failure_reason\"])\n  |> count()\n  |> keep(columns:[\"failure_reason\",\"_value\"])"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "piechart",
            "version": "13.0.1",
            "spec": {
              "options": {
                "legend": {
                  "displayMode": "list",
                  "placement": "bottom",
                  "showLegend": true
                },
                "pieType": "pie",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "sort": "desc",
                "tooltip": {
                  "hideZeros": false,
                  "mode": "single",
                  "sort": "none"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "s",
                  "color": {
                    "mode": "palette-classic"
                  },
                  "custom": {
                    "hideFrom": {
                      "legend": false,
                      "tooltip": false,
                      "viz": false
                    }
                  },
                  "fieldMinMax": false
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "scope": "series",
                      "options": "^_value (.*)"
                    },
                    "properties": [
                      {
                        "id": "displayName",
                        "value": "${__field.labels.failure_reason}"
                      }
                    ]
                  }
                ]
              }
            }
          },
          "transparent": true
        }
      }
    },
    "layout": {
      "kind": "GridLayout",
      "spec": {
        "items": [
          {
            "kind": "GridLayoutItem",
            "spec": {
              "x": 0,
              "y": 0,
              "width": 24,
              "height": 16,
              "element": {
                "kind": "ElementReference",
                "name": "panel-1"
              }
            }
          }
        ]
      }
    },
    "links": [],
    "liveNow": false,
    "preload": false,
    "tags": [],
